{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["**/dist/**", "**/coverage/**"],
  "overrides": [
    {
      "files": ["packages/core/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["react", "react/*", "react-dom", "react-dom/*", "pixi.js", "pixi.js/*"]
          }
        ]
      }
    }
  ]
}
