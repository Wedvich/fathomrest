{
  "name": "fathomrest",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter '@fathomrest/app' build",
    "dev": "bun run --filter '@fathomrest/app' dev",
    "format": "oxfmt .",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc && bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
